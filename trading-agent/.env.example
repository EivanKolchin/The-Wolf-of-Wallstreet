# .env.example

# Database Services
DATABASE_URL=sqlite+aiosqlite:///./trading-agent.db  # SQLite connection string
REDIS_URL=redis://localhost:6379/0                                  # Redis connection string

# AI/LLM API
AI_PROVIDER=ollama                                                  # 'anthropic', 'gemini', 'hybrid_claude', 'hybrid_gemini', or 'ollama'
ANTHROPIC_API_KEY=your_anthropic_api_key                            # Anthropic Claude API Key for text operations
GEMINI_API_KEY=your_gemini_api_key                                  # Google Gemini API Key for text operations
OLLAMA_MODEL=llama3                                                 # Local Ollama model name to use

# Exchange APIs
PAPER_MODE=true
ARBITRUM_RPC_URL=https://arb1.arbitrum.io/rpc
AGENT_WALLET_ADDRESS=0x0000000000000000000000000000000000000000
AGENT_PRIVATE_KEY=your_private_key_here
INITIAL_USDC_AMOUNT=1000.0

ALPACA_API_KEY=your_alpaca_api_key                                  # Alpaca API Key
ALPACA_SECRET_KEY=your_alpaca_secret                                # Alpaca API Secret

# On-Chain (Kite Chain) 
KITE_CHAIN_RPC_URL=https://rpc.kitechain.example.com                # Kite Chain RPC node URL
KITE_CHAIN_PRIVATE_KEY=your_private_key                             # Wallet private key for execution
KITE_AGENT_ADDRESS=0xYourAgentAddress                               # Contract or agent address

# Alternative Data Feeds
X_API_KEY=your_twitter_api_key                                      # Twitter/X API Key
X_API_SECRET=your_twitter_api_secret                                # Twitter/X API Secret
X_ACCESS_TOKEN=your_twitter_access_token                            # Twitter/X Access Token
X_ACCESS_TOKEN_SECRET=your_twitter_access_token_secret              # Twitter/X Access Token Secret
TELEGRAM_API_ID=your_telegram_api_id                                # Telegram API ID
TELEGRAM_API_HASH=your_telegram_api_hash                            # Telegram API Hash

# Application logs
LOG_LEVEL=INFO                                                      # Standard Python log levels
