# .env.example

# Database Services
DATABASE_URL=sqlite+aiosqlite:///./trading-agent.db  # SQLite connection string
REDIS_URL=redis://localhost:6379/0                                  # Redis connection string

# AI/LLM API
AI_PROVIDER=ollama                                                  # 'anthropic', 'gemini', 'hybrid_claude', 'hybrid_gemini', or 'ollama'
ANTHROPIC_API_KEY=your_anthropic_api_key                            # Anthropic Claude API Key for text operations
GEMINI_API_KEY=your_gemini_api_key                                  # Google Gemini API Key for text operations
OLLAMA_MODEL=llama3                                                 # Local Ollama model name to use
OLLAMA_FALLBACK_MODEL=                                              # Optional fallback model after OOM (blank disables fallback auto-switch)
AUTO_PULL_OLLAMA_MODELS=true                                        # If true, missing Ollama models are auto-downloaded

# Exchange APIs
PAPER_MODE=true
ARBITRUM_RPC_URL=https://arb1.arbitrum.io/rpc
AGENT_WALLET_ADDRESS=0x0000000000000000000000000000000000000000
AGENT_PRIVATE_KEY=your_private_key_here
INITIAL_USDC_AMOUNT=1000.0

ALPACA_API_KEY=your_alpaca_api_key                                  # Alpaca API Key (US stocks: data + execution)
ALPACA_SECRET_KEY=your_alpaca_secret                                # Alpaca API Secret

# Stock brokers besides Alpaca + optional free stock-data providers
IBKR_HOST=127.0.0.1                                                 # IB Gateway/TWS host (LSE leveraged-ETP execution)
IBKR_PORT=4002                                                     # 4002 paper gateway / 7497 paper TWS
IBKR_CLIENT_ID=11                                                  # ib_insync client id
IBKR_ACCOUNT_ID=your_ibkr_account_id                               # e.g. DU1234567 (paper) / U1234567 (live)
FINNHUB_API_KEY=your_finnhub_key                                   # optional free stock data provider
TWELVEDATA_API_KEY=your_twelvedata_key                             # optional free stock data provider

# Alternative Data Feeds
X_API_KEY=your_twitter_api_key                                      # Twitter/X API Key
X_API_SECRET=your_twitter_api_secret                                # Twitter/X API Secret
X_ACCESS_TOKEN=your_twitter_access_token                            # Twitter/X Access Token
X_ACCESS_TOKEN_SECRET=your_twitter_access_token_secret              # Twitter/X Access Token Secret
TELEGRAM_API_ID=your_telegram_api_id                                # Telegram API ID
TELEGRAM_API_HASH=your_telegram_api_hash                            # Telegram API Hash

# Application logs
LOG_LEVEL=INFO                                                      # Standard Python log levels

# Neural runtime calibration / online learning
NN_HOLD_PROB_MULTIPLIER=1.0                                         # Scales hold probability at inference time
NN_MIN_ACTION_CONFIDENCE=0.0                                        # If max class probability below this, force hold
NN_LONG_CONFIDENCE_THRESHOLD=0.0                                    # Optional long-specific confidence gate
NN_SHORT_CONFIDENCE_THRESHOLD=0.0                                   # Optional short-specific confidence gate
NN_ONLINE_PNL_NOISE_BAND=0.0005                                     # Ignore tiny pnl outcomes as noise
NN_ONLINE_PNL_WEIGHT_SCALE=0.01                                     # PnL-to-sample-weight scale in online updates
NN_ONLINE_WEIGHT_CAP=3.0                                            # Max per-sample online update weight
FEATURE_SCHEMA_VERSION=v2.0                                         # Feature layout version (FeatureSpec single source of truth)

# API rate limiting
BINANCE_RATE_LIMIT_PER_SEC=8.0                                     # Max Binance REST calls/sec per agent process

# Reinforcement learning (Advantage-Weighted Regression) + anti-inaction
NN_REWARD_K=10.0                                                   # tanh steepness on fee-net pnl
NN_HOLD_PENALTY=0.05                                               # penalty per horizon held beyond primary
NN_AWR_BETA=1.0                                                    # AWR temperature (higher = softer)
NN_AWR_WEIGHT_CAP=20.0                                             # max per-sample advantage weight
NN_IDLE_HOLD_DECAY=0.5                                             # hold prob scaled by (1-this) at full idle
NN_IDLE_PATIENCE=60                                                # no-trade cycles before idle pressure = 1.0
NN_MIN_EDGE_OVER_FEE=1.0                                           # require |edge| > this * round-trip fee to trade
